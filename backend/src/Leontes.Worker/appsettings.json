{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Signal": {
    "BaseUrl": "http://localhost:8081",
    "PollIntervalSeconds": 2
  },
  "Telegram": {
    "PollTimeoutSeconds": 30
  },
  "Api": {
    "BaseUrl": "http://localhost:5154"
  },
  "Sentinel": {
    "Enabled": true,
    "RateLimitPerMonitorPerMinute": 1,
    "QueueCapacity": 256,
    "Monitors": {
      "FileSystem": {
        "Enabled": true,
        "WatchPaths": [],
        "ExcludePatterns": ["*.tmp", "*.log"]
      },
      "Clipboard": {
        "Enabled": true,
        "PollIntervalSeconds": 2
      },
      "Calendar": {
        "Enabled": false,
        "PollIntervalMinutes": 5,
        "AlertMinutesBefore": 10
      },
      "ActiveWindow": {
        "Enabled": false,
        "DebounceMs": 500
      }
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Enrichers.ClientInfo"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [{ "Name": "Console" }],
    "Enrich": ["FromLogContext", "WithMachineName"]
  }
}
