{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Enrichers.ClientInfo"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": ["FromLogContext", "WithClientIp", "WithMachineName"]
  },
  "AiProvider": {
    "Provider": "ollama",
    "Endpoint": "http://localhost:11434",
    "Models": {
      "Large": {
        "Provider": "ollama",
        "ModelId": "llama3.1:8b"
      },
      "Small": {
        "Provider": "ollama",
        "ModelId": "qwen2.5:3b"
      }
    }
  },
  "Persona": {
    "InstructionsFile": "persona.md",
    "ConfidenceThreshold": 0.7,
    "ProactivityLevel": "Balanced",
    "StageSettings": {
      "Plan": { "ModelTier": "Large", "Temperature": 0.2 },
      "Execute": { "ModelTier": "Large", "Temperature": 0.5 },
      "Reflect": { "ModelTier": "Small", "Temperature": 0.1 },
      "Consolidation": { "ModelTier": "Small", "Temperature": 0.1 },
      "SentinelClassification": { "ModelTier": "Small", "Temperature": 0.2 }
    }
  },
  "ThinkingPipeline": {
    "DefaultQuestionTimeoutMinutes": 5,
    "MaxConversationHistoryMessages": 20,
    "MaxRelevantMemories": 10,
    "MemoryRelevanceThreshold": 0.7
  },
  "Resilience": {
    "QueueCapacity": 100,
    "EnqueueWaitSeconds": 5,
    "Llm": {
      "TimeoutSeconds": 60,
      "MaxRetries": 3,
      "RetryBaseDelaySeconds": 1,
      "ConsecutiveFailuresBeforeDegraded": 3,
      "DegradedWindowMinutes": 5
    },
    "RequestPort": {
      "QuestionTimeoutMinutes": 10,
      "ToolApprovalTimeoutMinutes": 30,
      "SentinelAlertTimeoutMinutes": 5,
      "PermissionTimeoutMinutes": 10
    },
    "ContextWindow": {
      "BufferPercentage": 10,
      "SummaryTriggerTurns": 20,
      "MinRecentTurns": 10,
      "DefaultModelTokenLimit": 8192,
      "AverageCharsPerToken": 4
    },
    "ChannelDelivery": {
      "MaxRetries": 2,
      "RetryDelaySeconds": 5
    },
    "Sentinel": {
      "MaxEventsPerMinutePerMonitor": 1,
      "QueueDepthLimit": 50
    },
    "DegradedMode": {
      "LlmPollIntervalSeconds": 30
    }
  },
  "Memory": {
    "ConsolidationIntervalHours": 1,
    "EmbeddingModelId": "all-minilm:l6-v2",
    "EmbeddingProvider": "ollama"
  },
  "CostControl": {
    "DailyTokenBudget": 500000,
    "WarningThresholdPercent": 75,
    "ThrottleThresholdPercent": 90,
    "HardStopEnabled": false,
    "HardStopThresholdPercent": 100,
    "BackgroundThrottleDelaySeconds": 30,
    "UsageRetentionDays": 90,
    "FeatureAllocations": {
      "Chat": 60,
      "Sentinel": 15,
      "Consolidation": 15,
      "ToolForge": 10
    },
    "ModelCosts": {}
  },
  "Vision": {
    "Enabled": true,
    "MaxTreeDepth": 8,
    "MaxTokenEstimate": 4000,
    "IncludeBounds": false,
    "RequireExplicitRequest": true,
    "ExcludePasswordFields": true,
    "ExcludedProcesses": [
      "1password", "keepass", "bitwarden", "lastpass",
      "mstsc", "vmconnect",
      "msedge", "chrome", "firefox"
    ]
  },
  "Telemetry": {
    "Enabled": true,
    "TraceRetentionDays": 30,
    "MetricsAggregationIntervalMinutes": 60,
    "ConfidenceThresholds": {
      "HighConfidence": 0.8,
      "LowConfidence": 0.5
    },
    "SensitiveFieldPatterns": [
      "password", "secret", "token", "key", "credential",
      "iban", "credit_card", "ssn"
    ]
  },
  "AllowedHosts": "*"
}
